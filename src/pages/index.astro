---
import Layout from '../layouts/Layout.astro';

// Fetch all markdown files in the posts directory
const posts = await Astro.glob('./posts/*.md');

// Sort posts by publication date descending
const sortedPosts = posts.sort(
  (a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);
---

<Layout title="João Brito | Journal">
  <section style="margin-bottom: 4rem;">
    <h1 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; letter-spacing: -0.03em;">Journal</h1>
    <p style="color: var(--text-primary); max-width: 580px; font-size: 1.15rem; line-height: 1.6; margin-bottom: 1rem;">
      Software Engineer at JPMorgan Chase and Information Engineering student at UFABC. Passionate about building robust backend logic, distributed systems, and scalable cloud infrastructure.
    </p>
    <p style="color: var(--text-secondary); max-width: 580px; font-size: 1.05rem; line-height: 1.6; margin-bottom: 0;">
      Prior experience includes designing automated data platforms and optimizing ETL pipelines at Itaú Unibanco. Certified AWS Cloud Practitioner and HashiCorp Terraform Associate. This journal serves as a repository of insights on software architecture, cloud engineering, and backend systems.
    </p>
  </section>

  <section>
    <h2 style="font-size: 1rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); margin-bottom: 2rem; border-bottom: none; padding-bottom: 0;">
      Articles
    </h2>
    
    {sortedPosts.length === 0 ? (
      <p style="color: var(--text-secondary); font-style: italic;">No posts found. Start by adding markdown files to <code style="font-size: 0.85em; background-color: var(--bg-secondary); padding: 0.2rem 0.4rem; border-radius: 4px;">src/pages/posts/</code>.</p>
    ) : (
      <ul class="post-list">
        {sortedPosts.map((post) => {
          const formattedDate = new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          });
          
          return (
            <li class="post-item">
              <span class="post-meta">{formattedDate}</span>
              <h3 class="post-title">
                <a href={post.url}>{post.frontmatter.title}</a>
              </h3>
              {post.frontmatter.description && (
                <p class="post-description">{post.frontmatter.description}</p>
              )}
            </li>
          );
        })}
      </ul>
    )}
  </section>
</Layout>
